{
  "name": "codex-cost",
  "version": "0.1.2",
  "description": "Local Codex JSONL usage and cost reporting CLI",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "keywords": [
    "codex",
    "cli",
    "usage",
    "cost",
    "xlsx"
  ],
  "homepage": "https://github.com/thebuilder/codex-cost#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/thebuilder/codex-cost.git"
  },
  "bugs": {
    "url": "https://github.com/thebuilder/codex-cost/issues"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "codex-cost": "./bin/codex-cost.mjs"
  },
  "scripts": {
    "codex-cost": "node src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "exceljs": "^4.4.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.1"
  },
  "pnpm": {
    "overrides": {
      "archiver-utils>glob": "^13.0.6",
      "exceljs>archiver": "^7.0.1",
      "exceljs>fast-csv": "^5.0.5",
      "exceljs>unzipper": "^0.12.3",
      "exceljs>uuid": "^11.1.0"
    }
  },
  "overrides": {
    "exceljs": {
      "archiver": "^7.0.1",
      "fast-csv": "^5.0.5",
      "unzipper": "^0.12.3",
      "uuid": "^11.1.0"
    },
    "archiver-utils": {
      "glob": "^13.0.6"
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
